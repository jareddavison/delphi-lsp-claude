# dcc64 build intermediates
obj/
tests/obj/
tests/bin/
*.dcu
*.o
*.identcache
*.tvsconfig
*.local

# Renamed-aside exe when rebuilding while the shim is running.
# The trailing * catches the .inuse2/.inuse3/... suffixes that pile up
# during back-to-back rebuilds (Windows holds the file open until the
# child process exits, so each rebuild needs its own rename target).
*.exe.inuse*

# Delphi IDE backups
__history/
__recovery/
*.~*

# IDE-generated LSP settings file — encodes per-machine RAD Studio install
# paths (DCU dirs, search paths to <BDS>\source\..., third-party libs at
# user-specific locations). Each developer regenerates locally by opening
# the .dproj in RAD Studio and saving (with the
# Tools → Options → ... → Save .delphilsp.json file when project is saved
# IDE option enabled). The .dproj itself IS committed — it's portable.
*.delphilsp.json
*.dproj.local

# Exception: the regression-test fixture's delphilsp.json IS committed,
# with a __PROJECT_DPR_URL__ placeholder the test substitutes per run.
!tests/fixtures/**/*.delphilsp.json

# Build artifacts that accumulate when the fixture project gets compiled
# (e.g., during a manual investigation of a regression-test failure).
tests/fixtures/**/Win32/
tests/fixtures/**/Win64/
tests/fixtures/**/*.exe

# Shim diagnostic logs
*.log

# OS / editor cruft
Thumbs.db
.DS_Store
*.swp

# Local-only resume / hand-off notes
NEXT_SESSION_PROMPT.md
