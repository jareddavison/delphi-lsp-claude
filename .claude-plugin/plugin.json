{
  "name": "delphi-lsp",
  "version": "0.5.0",
  "description": "Wires Embarcadero DelphiLSP into Claude Code's code-intelligence system for .pas/.dpr/.dpk/.inc files.",
  "license": "MIT",
  "author": { "name": "Jared Davison" },
  "homepage": "https://github.com/jareddavison/delphi-lsp-claude",
  "repository": "https://github.com/jareddavison/delphi-lsp-claude",
  "lspServers": {
    "delphilsp": {
      "command": "${CLAUDE_PLUGIN_ROOT}/bin/delphi-lsp-shim.exe",
      "extensionToLanguage": {
        ".pas": "objectpascal",
        ".inc": "objectpascal",
        ".dpr": "objectpascal",
        ".dpk": "objectpascal"
      }
    }
  }
}
